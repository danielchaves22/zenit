datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

enum Role {
  ADMIN
  SUPERUSER
  USER
}

enum AppKey {
  ZENIT_CASH
  ZENIT_CALC
  ZENIT_ADMIN
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  CASH
}

enum FinancialAccountPurpose {
  GENERAL
  BUDGET
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum FinancialTransactionEntryKind {
  NORMAL
  BALANCE_ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELED
}

enum CreditCardInvoiceStatus {
  OPEN
  CLOSED
  PAID
}

enum CreditCardInvoiceSettlementType {
  TRANSFER
  EXTERNAL
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ProcessStatus {
  SOLICITACAO
  INICIAL
  CALCULO
}

enum ProcessOriginType {
  MANUAL
  IMPORT
}

enum InitialCalculationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FgtsRegime {
  FGTS_8
  FGTS_11_2
}

enum CalculationVerbaScope {
  SYSTEM
  COMPANY
}

enum CalculationVerbaStrategy {
  MONTHLY_WITH_STANDARD_REFLEXES
  STANDARD_RESCISORY_BLOCK
  RESCISORY_NOTICE
  QUANTITY_X_HOURLY_RATE
  QUANTITY_X_DAILY_RATE
  MONTHS_X_REMUNERATION
  MONTHS_X_BASE_AMOUNT
  FIXED_AMOUNT
  CONDITIONAL_PENALTY_467
  CONDITIONAL_PENALTY_477
}

enum CalculationVerbaFgtsMode {
  REGIME
  FIXED_8
  NONE
}

enum CalculationVersionVerbaSource {
  TEMPLATE
  PROCESS_CUSTOM
  AD_HOC
}

enum CalculationLineType {
  PRINCIPAL
  REFLEXO_13
  REFLEXO_FERIAS
  REFLEXO_AVISO
  REFLEXO_DSR
  FGTS
  MULTA
  TOTAL
  OUTRA
}

enum InboundImportSourceType {
  EMAIL
}

enum InboundImportDestinationType {
  PROCESS
  CLIENT
  OTHER
}

enum AiProvider {
  OPENAI
}

enum GmailConnectionStatus {
  ACTIVE
  ERROR
  DISCONNECTED
}

enum ProcessSourceProvider {
  GMAIL
}

enum BudgetKind {
  SPENDING
  SAVINGS
}

enum BudgetStatus {
  ACTIVE
  ARCHIVED
  EXPIRED
  DELETED
}

enum BudgetEntryType {
  INCOME
  EXPENSE
  MANUAL_ADJUSTMENT
}

enum BudgetEntryAllocationMode {
  PRINCIPAL
  EXTRA
}

model User {
  id                  Int                   @id @default(autoincrement())
  email               String                @unique
  password            String
  name                String
  role                Role                  @default(USER)
  mustChangePassword        Boolean              @default(true)
  companies           UserCompany[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  financialTransactions FinancialTransaction[]
  recurringTransactions RecurringTransaction[]
  financialAccountAccess UserFinancialAccountAccess[]
  grantedPermissions     UserFinancialAccountAccess[] @relation("GrantedPermissions")
  appGrants             UserAppGrant[]
  preference             UserPreference?
  createdProcesses       Process[]            @relation("ProcessCreatedBy")
  updatedProcesses       Process[]            @relation("ProcessUpdatedBy")
  processStatusChanges   ProcessStatusHistory[] @relation("ProcessStatusHistoryChangedBy")
  personalWorkspaceOwned Company?             @relation("PersonalWorkspaceOwner")
  budgets                Budget[]
}

model Company {
  id                  Int                   @id @default(autoincrement())
  name                String
  address             String?
  code                Int                   @unique
  timeZone            String?
  isPersonalWorkspace Boolean               @default(false)
  personalWorkspaceOwnerId Int?             @unique
  users               UserCompany[]
  groups              CompanyGroup[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  financialAccounts   FinancialAccount[]
  financialCategories FinancialCategory[]
  financialTransactions FinancialTransaction[]
  financialTags       FinancialTag[]
  recurringTransactions RecurringTransaction[]
  userFinancialAccountAccess UserFinancialAccountAccess[]
  processes           Process[]
  processTags         ProcessTag[]
  inboundImports      InboundImport[]
  initialCalculations InitialCalculation[]
  processCustomVerbas ProcessCustomVerba[]
  calculationVerbaTemplates CalculationVerbaTemplate[]
  aiCredentials       CompanyAiCredential[]
  gmailConnection     GmailConnection?
  emailIngestionConfig EmailIngestionConfig?
  appEntitlements     CompanyAppEntitlement[]
  userAppGrants       UserAppGrant[]
  personalWorkspaceOwner User?              @relation("PersonalWorkspaceOwner", fields: [personalWorkspaceOwnerId], references: [id], onDelete: SetNull)
  budgets             Budget[]
}

model CompanyGroup {
  id        Int       @id @default(autoincrement())
  name      String
  companies Company[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model UserCompany {
  id        Int     @id @default(autoincrement())
  userId    Int
  companyId Int
  isDefault Boolean @default(false)
  role      Role    @default(USER)
  isCompanyOwner           Boolean @default(false)
  manageFinancialAccounts   Boolean @default(false)
  manageFinancialCategories Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@index([companyId, isCompanyOwner])
}

model EcosystemApp {
  id        Int      @id @default(autoincrement())
  appKey    AppKey   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyEntitlements CompanyAppEntitlement[]
  userGrants          UserAppGrant[]
}

model CompanyAppEntitlement {
  id         Int      @id @default(autoincrement())
  companyId  Int
  appId      Int
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  app        EcosystemApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([companyId, appId], name: "unique_company_app_entitlement")
  @@index([companyId])
  @@index([appId])
}

model Bank {
  id           Int                @id @default(autoincrement())
  code         String             @unique
  name         String             @unique
  iconSlug     String
  displayOrder Int                @default(0)
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  accounts     FinancialAccount[]

  @@index([isActive, displayOrder])
}

model UserAppGrant {
  id         Int      @id @default(autoincrement())
  userId     Int
  companyId  Int
  appId      Int
  granted    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  app        EcosystemApp @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, appId], name: "unique_user_company_app_grant")
  @@index([userId])
  @@index([companyId])
  @@index([appId])
}

model FinancialAccount {
  id                Int                 @id @default(autoincrement())
  name              String
  type              AccountType
  purpose           FinancialAccountPurpose @default(GENERAL)
  balance           Decimal            @db.Decimal(15, 2) @default(0)
  accountNumber     String?
  bankName          String?
  bankCode          String?
  bankId            Int?
  creditLimit       Decimal?            @db.Decimal(15, 2)
  cardColor         String?
  statementClosingDay Int?
  statementDueDay   Int?
  isActive          Boolean            @default(true)
  isDefault         Boolean            @default(false)
  allowNegativeBalance Boolean         @default(false)
  isSystemManaged   Boolean            @default(false)
  companyId         Int
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bank              Bank?              @relation(fields: [bankId], references: [id], onDelete: SetNull)
  recurringOutgoing RecurringTransaction[] @relation("RecurringFromAccount")
  recurringIncoming RecurringTransaction[] @relation("RecurringToAccount")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  // Relações
  outgoingTransactions FinancialTransaction[] @relation("FromAccount")
  incomingTransactions FinancialTransaction[] @relation("ToAccount")
  creditCardInvoices   CreditCardInvoice[]
  userAccess            UserFinancialAccountAccess[]
  budget                Budget?

  @@unique([name, type, companyId])
  @@index([bankId])
  @@index([companyId])
  @@index([companyId, isDefault]) // ✅ ÍNDICE OTIMIZADO
}

model FinancialCategory {
  id              Int                  @id @default(autoincrement())
  name            String
  type            TransactionType      @default(EXPENSE)
  color           String               @default("#6366F1")
  icon            String               @default("tag")
  isDefault       Boolean              @default(false)  // ✅ NOVO CAMPO
  parentId        Int?
  parent          FinancialCategory?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        FinancialCategory[]  @relation("CategoryHierarchy")
  companyId       Int
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountingCode  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  
  // Relações
  transactions    FinancialTransaction[]
  recurringTransactions RecurringTransaction[]

  @@unique([name, parentId, companyId])
  @@index([companyId])
  @@index([parentId])
  @@index([companyId, type, isDefault]) // ✅ ÍNDICE OTIMIZADO
}

model FinancialTransaction {
  id              Int                  @id @default(autoincrement())
  description     String
  amount          Decimal              @db.Decimal(15, 2)
  
  // ✅ DATAS MÚLTIPLAS
  date            DateTime             // Data principal (competência/referência)
  dueDate         DateTime?            // Data de vencimento (para PENDING)
  effectiveDate   DateTime?            // Data de efetivação (para COMPLETED)
  
  // ✅ VALORES MÚLTIPLOS (preparação para futuro)
  originalAmount  Decimal?             @db.Decimal(15, 2) // Valor original
  paidAmount      Decimal?             @db.Decimal(15, 2) // Valor pago (com juros/desconto)

  // ✅ CONTROLE DE PARCELAS
  installmentNumber  Int?
  totalInstallments  Int?
  purchaseGroupId    String?
  
  type            TransactionType
  entryKind       FinancialTransactionEntryKind @default(NORMAL)
  status          TransactionStatus    @default(COMPLETED) // ✅ MUDANÇA: padrão COMPLETED
  notes           String?
  fromAccountId   Int?
  fromAccount     FinancialAccount?    @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccountId     Int?
  toAccount       FinancialAccount?    @relation("ToAccount", fields: [toAccountId], references: [id])
  categoryId      Int?
  category        FinancialCategory?   @relation(fields: [categoryId], references: [id])
  creditCardInvoiceId Int?
  creditCardInvoice   CreditCardInvoice? @relation("InvoiceTransactions", fields: [creditCardInvoiceId], references: [id], onDelete: SetNull)
  isExternalCreditCardSettlement Boolean @default(false)
  companyId       Int
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy       Int
  createdByUser   User                 @relation(fields: [createdBy], references: [id])
  paidInvoice     CreditCardInvoice?   @relation("InvoicePaymentTransaction")
  tags            FinancialTag[]
  scheduledDate           DateTime?
  recurringTransactionId  Int?
  recurringTransaction    RecurringTransaction? @relation(fields: [recurringTransactionId], references: [id])
  budgetEntry            BudgetEntry?
  occurrenceKey    String?              @unique
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // ✅ ÍNDICES EXISTENTES
  @@index([companyId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([categoryId])
  @@index([date])
  @@index([purchaseGroupId])
  @@index([creditCardInvoiceId])
  @@index([companyId, entryKind])
  
  // ✅ NOVOS ÍNDICES PARA PERFORMANCE
  @@index([dueDate, status])                              // Relatórios de inadimplência
  @@index([effectiveDate])                               // Conciliação bancária
  @@index([companyId, effectiveDate, status])           // Relatórios financeiros
}

model CreditCardInvoice {
  id                   Int                     @id @default(autoincrement())
  accountId            Int
  account              FinancialAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  referenceYear        Int
  referenceMonth       Int
  closingDate          DateTime
  dueDate              DateTime
  status               CreditCardInvoiceStatus @default(OPEN)
  settlementType       CreditCardInvoiceSettlementType?
  settledAt            DateTime?
  totalAmount          Decimal                 @db.Decimal(15, 2) @default(0)
  paymentTransactionId Int?                    @unique
  paymentTransaction   FinancialTransaction?   @relation("InvoicePaymentTransaction", fields: [paymentTransactionId], references: [id], onDelete: SetNull)
  transactions         FinancialTransaction[]  @relation("InvoiceTransactions")
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@unique([accountId, referenceYear, referenceMonth], name: "unique_credit_card_invoice_reference")
  @@index([accountId, dueDate])
  @@index([status, dueDate])
}

model RecurringTransaction {
  id              Int                  @id @default(autoincrement())
  description     String
  amount          Decimal              @db.Decimal(15, 2)
  type            TransactionType
  frequency       RecurringFrequency
  dayOfMonth      Int?                 // Para MONTHLY: dia do mês (1-31)
  dayOfWeek       Int?                 // Para WEEKLY: dia da semana (0-6)
  startDate       DateTime
  endDate         DateTime?            // null = sem fim
  nextDueDate     DateTime
  isActive        Boolean              @default(true)
  notes           String?
  fromAccountId   Int?
  fromAccount     FinancialAccount?    @relation("RecurringFromAccount", fields: [fromAccountId], references: [id])
  toAccountId     Int?
  toAccount       FinancialAccount?    @relation("RecurringToAccount", fields: [toAccountId], references: [id])
  categoryId      Int?
  category        FinancialCategory?   @relation(fields: [categoryId], references: [id])
  companyId       Int
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy       Int
  createdByUser   User                 @relation(fields: [createdBy], references: [id]) // ✅ CORRIGIDO
  transactions    FinancialTransaction[] // Transações geradas
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([companyId])
  @@index([type])
  @@index([nextDueDate])
  @@index([isActive])
}

model FinancialTag {
  id              Int                  @id @default(autoincrement())
  name            String
  companyId       Int
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions    FinancialTransaction[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([name, companyId])
  @@index([companyId])
}

model UserFinancialAccountAccess {
  id                   Int              @id @default(autoincrement())
  userId               Int
  financialAccountId   Int
  companyId            Int              // Garantir que só pode dar acesso a contas da mesma empresa
  grantedBy            Int              // Quem concedeu a permissão
  grantedAt            DateTime         @default(now())
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  
  // Relações
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialAccount     FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  grantedByUser        User             @relation("GrantedPermissions", fields: [grantedBy], references: [id])

  // Constraints
  @@unique([userId, financialAccountId], name: "unique_user_account_access")
  @@index([userId])
  @@index([financialAccountId])
  @@index([companyId])
  @@index([grantedBy])
}

model Budget {
  id                  Int              @id @default(autoincrement())
  companyId           Int
  userId              Int
  clientKey           String
  code                String
  kind                BudgetKind
  status              BudgetStatus     @default(ACTIVE)
  initialBalance      Decimal          @db.Decimal(15, 2)
  currentBalance      Decimal          @db.Decimal(15, 2)
  targetEndingBalance Decimal          @db.Decimal(15, 2) @default(0)
  dailyBudgetInitial  Decimal          @db.Decimal(15, 2)
  dailyBudgetCurrent  Decimal          @db.Decimal(15, 2)
  dayExtraBalance     Decimal          @db.Decimal(15, 2) @default(0)
  startDate           DateTime
  endDate             DateTime
  lastDailyBudgetDate DateTime
  isPrimary           Boolean          @default(false)
  financialAccountId  Int              @unique
  clientCreatedAt     DateTime
  clientUpdatedAt     DateTime
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  company             Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialAccount    FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  entries             BudgetEntry[]

  @@unique([companyId, userId, clientKey], name: "unique_budget_client_key")
  @@index([companyId, userId])
  @@index([companyId, status])
}

model BudgetEntry {
  id                    Int                        @id @default(autoincrement())
  budgetId              Int
  clientKey             String
  entryType             BudgetEntryType
  allocationMode        BudgetEntryAllocationMode?
  amount                Decimal                    @db.Decimal(15, 2)
  principalImpactAmount Decimal                    @db.Decimal(15, 2) @default(0)
  occurredAt            DateTime
  description           String?
  affectsBudgetBalance  Boolean                    @default(true)
  financialTransactionId Int?                      @unique
  clientCreatedAt       DateTime
  clientUpdatedAt       DateTime
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  budget                Budget                     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  financialTransaction  FinancialTransaction?      @relation(fields: [financialTransactionId], references: [id], onDelete: SetNull)

  @@unique([budgetId, clientKey], name: "unique_budget_entry_client_key")
  @@index([budgetId, occurredAt])
}

model Process {
  id                  Int                @id @default(autoincrement())
  companyId           Int
  status              ProcessStatus
  requestingLawyerName String?
  claimantName        String?
  notes               String?
  originType          ProcessOriginType  @default(MANUAL)
  sourceImportId      Int?               @unique
  sourceProvider      ProcessSourceProvider?
  sourceThreadId      String?
  createdBy           Int
  updatedBy           Int?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceImport        InboundImport?     @relation(fields: [sourceImportId], references: [id], onDelete: SetNull)
  createdByUser       User               @relation("ProcessCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  updatedByUser       User?              @relation("ProcessUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  statusHistory       ProcessStatusHistory[]
  processTags         ProcessTagLink[]
  initialCalculation  InitialCalculation?
  customVerbas        ProcessCustomVerba[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([companyId, deletedAt])
  @@unique([companyId, sourceProvider, sourceThreadId], name: "unique_process_per_company_source_thread")
}

model ProcessStatusHistory {
  id          Int           @id @default(autoincrement())
  processId   Int
  fromStatus  ProcessStatus?
  toStatus    ProcessStatus
  changedBy   Int
  changedAt   DateTime      @default(now())
  reason      String?

  process     Process       @relation(fields: [processId], references: [id], onDelete: Cascade)
  changedByUser User        @relation("ProcessStatusHistoryChangedBy", fields: [changedBy], references: [id], onDelete: Cascade)

  @@index([processId])
  @@index([changedBy])
  @@index([changedAt])
}

model ProcessTag {
  id          Int           @id @default(autoincrement())
  name        String
  companyId   Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  processes   ProcessTagLink[]

  @@unique([companyId, name])
  @@index([companyId])
}

model ProcessTagLink {
  id          Int           @id @default(autoincrement())
  processId   Int
  tagId       Int
  createdAt   DateTime      @default(now())

  process     Process       @relation(fields: [processId], references: [id], onDelete: Cascade)
  tag         ProcessTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([processId, tagId], name: "unique_process_tag_link")
  @@index([processId])
  @@index([tagId])
}

model InboundImport {
  id              Int                         @id @default(autoincrement())
  companyId       Int
  connectionId    Int?
  sourceType      InboundImportSourceType    @default(EMAIL)
  externalId      String
  externalThreadId String?
  payloadMetadata Json?
  destinationType InboundImportDestinationType?
  destinationId   String?
  processedAt     DateTime?
  sourceReceivedAt DateTime?
  createdAt       DateTime                    @default(now())

  company         Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connection      GmailConnection?            @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  process         Process?

  @@unique([companyId, sourceType, externalId], name: "unique_inbound_import_per_company_source")
  @@index([companyId])
  @@index([connectionId])
  @@index([companyId, createdAt])
  @@index([companyId, destinationType])
  @@index([companyId, processedAt])
  @@index([companyId, externalThreadId])
}

model CalculationRuleSet {
  id          Int        @id @default(autoincrement())
  code        String     @unique
  name        String
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  versions    InitialCalculationVersion[]
}

model CalculationVerbaTemplate {
  id              Int                        @id @default(autoincrement())
  companyId       Int?
  scope           CalculationVerbaScope     @default(SYSTEM)
  code            String                     @unique
  label           String
  groupCode       String
  groupLabel      String
  strategy        CalculationVerbaStrategy
  fgtsMode        CalculationVerbaFgtsMode  @default(NONE)
  configJson      Json?
  inputSchemaJson Json?
  sortOrder       Int                        @default(0)
  isActive        Boolean                    @default(true)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  company         Company?                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  versionVerbas   InitialCalculationVersionVerba[]

  @@index([companyId])
  @@index([scope, isActive])
  @@index([groupCode, sortOrder])
}

model ProcessCustomVerba {
  id              Int                        @id @default(autoincrement())
  processId       Int
  companyId       Int
  code            String
  label           String
  groupCode       String
  groupLabel      String
  strategy        CalculationVerbaStrategy
  fgtsMode        CalculationVerbaFgtsMode  @default(NONE)
  configJson      Json?
  inputSchemaJson Json?
  sortOrder       Int                        @default(0)
  isActive        Boolean                    @default(true)
  createdBy       Int
  updatedBy       Int?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  process         Process                    @relation(fields: [processId], references: [id], onDelete: Cascade)
  company         Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  versionVerbas   InitialCalculationVersionVerba[]

  @@unique([processId, code], name: "unique_process_custom_verba_code")
  @@index([companyId])
  @@index([processId, isActive])
}

model InitialCalculation {
  id                        Int                       @id @default(autoincrement())
  processId                 Int                       @unique
  companyId                 Int
  status                    InitialCalculationStatus  @default(DRAFT)
  currentPublishedVersionId Int?                      @unique
  createdBy                 Int
  updatedBy                 Int?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  process                   Process                    @relation(fields: [processId], references: [id], onDelete: Cascade)
  company                   Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currentPublishedVersion   InitialCalculationVersion? @relation("InitialCalculationCurrentPublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: SetNull)
  versions                  InitialCalculationVersion[] @relation("InitialCalculationVersions")

  @@index([companyId])
  @@index([status])
}

model InitialCalculationVersion {
  id                   Int                            @id @default(autoincrement())
  initialCalculationId Int
  versionNumber        Int
  ruleSetId            Int
  fgtsRegime           FgtsRegime
  inputSnapshotJson    Json
  summarySnapshotJson  Json?
  publishedAt          DateTime?
  createdBy            Int
  createdAt            DateTime                       @default(now())

  initialCalculation   InitialCalculation             @relation("InitialCalculationVersions", fields: [initialCalculationId], references: [id], onDelete: Cascade)
  currentForCalculation InitialCalculation?           @relation("InitialCalculationCurrentPublishedVersion")
  ruleSet              CalculationRuleSet             @relation(fields: [ruleSetId], references: [id], onDelete: Restrict)
  verbas               InitialCalculationVersionVerba[]

  @@unique([initialCalculationId, versionNumber], name: "unique_initial_calculation_version_number")
  @@index([ruleSetId])
  @@index([publishedAt])
}

model InitialCalculationVersionVerba {
  id                    Int                           @id @default(autoincrement())
  versionId             Int
  sourceType            CalculationVersionVerbaSource
  templateId            Int?
  processCustomVerbaId  Int?
  verbaCode             String
  verbaLabel            String
  groupCode             String
  groupLabel            String
  strategy              CalculationVerbaStrategy
  fgtsMode              CalculationVerbaFgtsMode     @default(NONE)
  configJson            Json?
  inputSchemaJson       Json?
  isEnabled             Boolean                      @default(true)
  sortOrder             Int                          @default(0)
  createdAt             DateTime                     @default(now())

  version               InitialCalculationVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  template              CalculationVerbaTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  processCustomVerba    ProcessCustomVerba?          @relation(fields: [processCustomVerbaId], references: [id], onDelete: SetNull)
  linhasResultado       InitialCalculationLine[]

  @@index([versionId, sortOrder])
  @@index([templateId])
  @@index([processCustomVerbaId])
  @@index([groupCode])
}

model InitialCalculationLine {
  id             Int                  @id @default(autoincrement())
  versionVerbaId Int
  lineType       CalculationLineType
  label          String
  amount         Decimal              @db.Decimal(15, 2)
  sortOrder      Int                  @default(0)
  memoryJson     Json?
  createdAt      DateTime             @default(now())

  versionVerba   InitialCalculationVersionVerba @relation(fields: [versionVerbaId], references: [id], onDelete: Cascade)

  @@index([versionVerbaId, sortOrder])
  @@index([lineType])
}

model CompanyAiCredential {
  id              Int        @id @default(autoincrement())
  companyId       Int
  provider        AiProvider @default(OPENAI)
  apiKeyCiphertext String
  apiKeyIv        String
  apiKeyTag       String
  model           String     @default("gpt-5.4-nano")
  promptVersion   String     @default("v1")
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider], name: "unique_ai_credential_per_company_provider")
  @@index([companyId])
}

model GmailConnection {
  id                     Int                   @id @default(autoincrement())
  companyId              Int                   @unique
  googleEmail            String
  googleUserId           String?
  refreshTokenCiphertext String
  refreshTokenIv         String
  refreshTokenTag        String
  accessTokenCiphertext  String?
  accessTokenIv          String?
  accessTokenTag         String?
  accessTokenExpiresAt   DateTime?
  status                 GmailConnectionStatus @default(ACTIVE)
  watchExpiration        DateTime?
  lastError              String?
  disabledAt             DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  company                Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  syncState              GmailSyncState?
  inboundImports         InboundImport[]

  @@index([companyId, status])
  @@index([googleEmail])
}

model GmailSyncState {
  id                    Int             @id @default(autoincrement())
  connectionId          Int             @unique
  lastHistoryId         String?
  lastPollingAt         DateTime?
  lastReconcileAt       DateTime?
  lastProcessedMessageAt DateTime?
  updatedAt             DateTime        @updatedAt

  connection            GmailConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model EmailIngestionConfig {
  id                           Int       @id @default(autoincrement())
  companyId                    Int       @unique
  enabled                      Boolean   @default(false)
  subjectRequiredText          String    @default("Inicial Trabalhista")
  lookbackDays                 Int       @default(3)
  pollingIntervalMinutes       Int       @default(5)
  reconciliationIntervalMinutes Int      @default(60)
  maxEmailsPerRun              Int       @default(50)
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  company                      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id Int @id @default(autoincrement())
  userId Int @unique
  colorScheme String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
