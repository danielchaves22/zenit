# ============================================
# backend/.env.docker (DESENVOLVIMENTO DOCKER)
# ============================================
DATABASE_URL="postgresql://postgres:postgres@zenit-db:5432/zenit?schema=public"
PORT=3000
JWT_SECRET="docker-dev-secret-change-in-production-32-chars"
NODE_ENV=development

# ✅ REDIS - DESABILITADO POR PADRÃO (usar memory store)
REDIS_ENABLED=false
REDIS_HOST="redis"
REDIS_PORT="6379"
# REDIS_PASSWORD="" # Sem senha em dev

# CORS Docker
FRONTEND_URL="http://localhost:3001"
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:3000"

# Rate limiting (desenvolvimento com memory store)
RATE_LIMIT_WINDOW="900000"
RATE_LIMIT_MAX="1000"

# Logs
LOG_LEVEL=debug
LOG_TO_FILE=true

# Database Docker
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_NAME="zenit"

BCRYPT_ROUNDS=12
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Integracoes (Gmail + OpenAI BYOK)
INTEGRATION_SECRETS_MASTER_KEY="defina-uma-chave-forte"
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET=""
GMAIL_OAUTH_REDIRECT_URI=""
GMAIL_PUBSUB_TOPIC=""
GMAIL_WEBHOOK_SECRET=""
WEBHOOK_BASE_URL=""
GMAIL_WORKER_INTERVAL_MS=60000

WHATSAPP_API_VERSION="v23.0"
